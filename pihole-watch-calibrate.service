[Unit]
Description=Pi-hole watch -- autonomous threshold calibration
After=network-online.target docker.service

[Service]
Type=oneshot
User=pistrommy
WorkingDirectory=/home/pistrommy/projects/pihole-watch
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=/home/pistrommy/projects
ExecStart=/home/pistrommy/projects/pihole-watch/.venv/bin/python -m pihole_watch.cli calibrate

[Install]
WantedBy=multi-user.target
